# ══════════════════════════════════════════════════════════════════════════════
# LocalXpress Backend — Environment Variables Template
# Copia este archivo a .env y rellena los valores
# ══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production            # development | production | test
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
# En ejecución local directa: apuntar a 127.0.0.1
# En Docker Compose: el compose sobreescribe esto con el host interno "postgres"
DATABASE_URL=postgresql://localxpress:CHANGE_ME@localhost:5432/localxpress

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Generar con: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_random_characters_here
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por comas. En producción: dominio del frontend
CORS_ORIGIN=http://localhost:5173

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_DIR=./uploads          # Ruta relativa al directorio del backend
MAX_FILE_SIZE_MB=10

# ─── B2B API Key (endpoint /api/stops/order) ──────────────────────────────────
# Generar con: openssl rand -hex 32
API_KEY_CREATE_ORDER=CHANGE_ME

# ─── External Services (opcionales) ──────────────────────────────────────────
GOOGLE_MAPS_API_KEY=           # Para calculate-route y places-autocomplete
RESEND_API_KEY=                # Para notificaciones email
RESEND_FROM=noreply@tudominio.com
NOTIFICATION_EMAIL=admin@tudominio.com
