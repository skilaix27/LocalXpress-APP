# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localxpress:password@localhost:5432/localxpress

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_this_with_at_least_48_random_characters_please
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── B2B API Key (for create-order endpoint) ──────────────────────────────────
API_KEY_CREATE_ORDER=replace_with_a_secure_random_key

# ─── External Services (optional, for future use) ─────────────────────────────
GOOGLE_MAPS_API_KEY=
RESEND_API_KEY=
RESEND_FROM=noreply@localxpress.com
NOTIFICATION_EMAIL=admin@localxpress.com
