# ══════════════════════════════════════════════════════════════════════════════
# LocalXpress — Nginx configuration
# VPS: 109.176.197.56
#
# Copiar a: /etc/nginx/sites-available/localxpress
# Activar:  ln -s /etc/nginx/sites-available/localxpress /etc/nginx/sites-enabled/
# Test:     nginx -t
# Reload:   systemctl reload nginx
#
# Para SSL con Let's Encrypt (cuando tengas dominio):
#   certbot --nginx -d tudominio.com
# ══════════════════════════════════════════════════════════════════════════════

# ─── Sin dominio: acceso por IP directa ──────────────────────────────────────
server {
    listen 80;
    server_name 109.176.197.56;

    # ─── Seguridad básica ────────────────────────────────────────────────────
    add_header X-Frame-Options        "SAMEORIGIN"    always;
    add_header X-Content-Type-Options "nosniff"       always;
    add_header Referrer-Policy        "strict-origin" always;

    # ─── Frontend (build estático de React/Vite) ─────────────────────────────
    root /var/www/localxpress/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Cache para assets con hash en el nombre
    location ~* \.(js|css|woff2|png|jpg|svg|ico|webp)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # ─── Backend API (proxy inverso al contenedor Docker) ────────────────────
    location /api/ {
        proxy_pass         http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;

        # Límite de tamaño para subida de fotos (debe ser >= MAX_FILE_SIZE_MB + margen)
        client_max_body_size 12m;
    }

    # ─── Archivos subidos (fotos de entrega) ─────────────────────────────────
    location /uploads/ {
        proxy_pass http://127.0.0.1:3001/uploads/;
        proxy_set_header Host $host;
        expires 1h;
        add_header Cache-Control "public, max-age=3600";
    }

    # ─── Logs ────────────────────────────────────────────────────────────────
    access_log /var/log/nginx/localxpress.access.log;
    error_log  /var/log/nginx/localxpress.error.log;
}

